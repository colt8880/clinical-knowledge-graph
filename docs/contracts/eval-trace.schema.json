{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clinical-knowledge-graph/contracts/eval-trace.schema.json",
  "title": "EvalTrace",
  "description": "v1 (F21). Machine-readable pairing of docs/specs/eval-trace.md. The evaluator's primary output. Every event carries a guideline_id field; envelope-level events (evaluation_started, evaluation_completed) use null.",
  "type": "object",
  "required": ["envelope", "events", "recommendations", "recommendations_by_guideline"],
  "additionalProperties": false,
  "properties": {
    "envelope": { "$ref": "#/$defs/Envelope" },
    "events": { "type": "array", "items": { "$ref": "#/$defs/Event" }, "minItems": 2 },
    "recommendations": { "type": "array", "items": { "$ref": "#/$defs/Recommendation" }, "default": [] },
    "recommendations_by_guideline": {
      "type": "object",
      "description": "Per-guideline breakdown of recommendations, keyed by guideline_id. Derived from the same trace as the flat recommendations list.",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/Recommendation" }
      }
    }
  },
  "$defs": {
    "Envelope": {
      "type": "object",
      "required": ["spec_tag", "graph_version", "evaluator_version", "evaluation_time", "patient_fingerprint"],
      "properties": {
        "spec_tag": { "type": "string" },
        "graph_version": { "type": "string" },
        "evaluator_version": { "type": "string" },
        "evaluation_time": { "type": "string", "format": "date-time" },
        "patient_fingerprint": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "TriState": { "type": "string", "enum": ["true", "false", "unknown"] },
    "InputRead": {
      "type": "object",
      "required": ["source", "locator", "present"],
      "properties": {
        "source": { "type": "string", "enum": ["patient.demographics", "patient.conditions", "patient.observations", "patient.medications", "patient.social_history", "patient.risk_scores", "patient.completeness", "derived"] },
        "locator": { "type": "string" },
        "value": {},
        "present": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "Event": {
      "oneOf": [
        { "$ref": "#/$defs/EvaluationStarted" },
        { "$ref": "#/$defs/GuidelineEntered" },
        { "$ref": "#/$defs/GuidelineExited" },
        { "$ref": "#/$defs/RecommendationConsidered" },
        { "$ref": "#/$defs/EligibilityEvaluationStarted" },
        { "$ref": "#/$defs/PredicateEvaluated" },
        { "$ref": "#/$defs/CompositeResolved" },
        { "$ref": "#/$defs/EligibilityEvaluationCompleted" },
        { "$ref": "#/$defs/StrategyConsidered" },
        { "$ref": "#/$defs/ActionChecked" },
        { "$ref": "#/$defs/StrategyResolved" },
        { "$ref": "#/$defs/RiskScoreLookup" },
        { "$ref": "#/$defs/ExitConditionTriggered" },
        { "$ref": "#/$defs/RecommendationEmitted" },
        { "$ref": "#/$defs/EvaluationCompleted" },
        { "$ref": "#/$defs/CrossGuidelineMatch" },
        { "$ref": "#/$defs/PreemptionResolved" }
      ]
    },
    "BaseEvent": {
      "type": "object",
      "required": ["seq", "type", "guideline_id"],
      "properties": {
        "seq": { "type": "integer", "minimum": 1 },
        "type": { "type": "string" },
        "guideline_id": { "type": ["string", "null"], "description": "The guideline being evaluated when this event was emitted. Null for envelope-level events (evaluation_started, evaluation_completed)." },
        "at": { "type": "string", "format": "date-time" }
      }
    },
    "EvaluationStarted": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "patient_age_years", "patient_sex", "guidelines_in_scope"],
      "properties": {
        "type": { "const": "evaluation_started" },
        "guideline_id": { "const": null },
        "patient_age_years": { "type": "integer" },
        "patient_sex": { "type": "string" },
        "guidelines_in_scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "GuidelineEntered": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "guideline_title"],
      "properties": {
        "type": { "const": "guideline_entered" },
        "guideline_id": { "type": "string" },
        "guideline_title": { "type": "string" }
      }
    },
    "GuidelineExited": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendations_emitted"],
      "properties": {
        "type": { "const": "guideline_exited" },
        "guideline_id": { "type": "string" },
        "recommendations_emitted": { "type": "integer", "minimum": 0 }
      }
    },
    "RecommendationConsidered": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "recommendation_title", "evidence_grade", "intent", "trigger"],
      "properties": {
        "type": { "const": "recommendation_considered" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "recommendation_title": { "type": "string" },
        "evidence_grade": { "type": "string" },
        "intent": { "type": "string" },
        "trigger": { "type": "string" }
      }
    },
    "EligibilityEvaluationStarted": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id"],
      "properties": {
        "type": { "const": "eligibility_evaluation_started" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" }
      }
    },
    "PredicateEvaluated": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "path", "predicate", "args", "inputs_read", "result"],
      "properties": {
        "type": { "const": "predicate_evaluated" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "path": { "type": "array", "items": { "type": ["string", "integer"] } },
        "predicate": { "type": "string" },
        "args": { "type": "object" },
        "inputs_read": { "type": "array", "items": { "$ref": "#/$defs/InputRead" } },
        "result": { "$ref": "#/$defs/TriState" },
        "missing_data_policy_applied": { "type": ["string", "null"], "enum": ["require", "fail_open", "fail_closed", null] },
        "note": { "type": ["string", "null"] }
      }
    },
    "CompositeResolved": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "path", "operator", "result", "short_circuited"],
      "properties": {
        "type": { "const": "composite_resolved" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "path": { "type": "array", "items": { "type": ["string", "integer"] } },
        "operator": { "type": "string", "enum": ["all_of", "any_of", "none_of"] },
        "result": { "$ref": "#/$defs/TriState" },
        "short_circuited": { "type": "boolean" }
      }
    },
    "EligibilityEvaluationCompleted": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "result", "final_value"],
      "properties": {
        "type": { "const": "eligibility_evaluation_completed" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "result": { "type": "string", "enum": ["eligible", "ineligible", "unknown"] },
        "final_value": { "$ref": "#/$defs/TriState" }
      }
    },
    "StrategyConsidered": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "strategy_id", "strategy_name"],
      "properties": {
        "type": { "const": "strategy_considered" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "strategy_id": { "type": "string" },
        "strategy_name": { "type": "string" }
      }
    },
    "ActionChecked": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "strategy_id", "action_node_id", "action_entity_type", "inputs_read", "satisfied"],
      "properties": {
        "type": { "const": "action_checked" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "strategy_id": { "type": "string" },
        "action_node_id": { "type": "string" },
        "action_entity_type": { "type": "string", "enum": ["Medication", "Procedure", "Observation"] },
        "cadence": { "type": ["string", "null"] },
        "lookback": { "type": ["string", "null"] },
        "inputs_read": { "type": "array", "items": { "$ref": "#/$defs/InputRead" } },
        "satisfied": { "type": "boolean" },
        "note": { "type": ["string", "null"] }
      }
    },
    "StrategyResolved": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "strategy_id", "satisfied"],
      "properties": {
        "type": { "const": "strategy_resolved" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "strategy_id": { "type": "string" },
        "satisfied": { "type": "boolean" }
      }
    },
    "RiskScoreLookup": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "score_name", "resolution"],
      "properties": {
        "type": { "const": "risk_score_lookup" },
        "guideline_id": { "type": "string" },
        "score_name": { "type": "string" },
        "resolution": { "type": "string", "enum": ["supplied", "computed", "unavailable"] },
        "supplied_value": { "type": ["number", "null"] },
        "supplied_computed_date": { "type": ["string", "null"] },
        "inputs_read": { "type": "array", "items": { "$ref": "#/$defs/InputRead" } },
        "computed_value": { "type": ["number", "null"] },
        "method": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"] }
      }
    },
    "ExitConditionTriggered": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "exit", "rationale"],
      "properties": {
        "type": { "const": "exit_condition_triggered" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "exit": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },
    "RecommendationEmitted": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendation_id", "status", "evidence_grade", "reason"],
      "properties": {
        "type": { "const": "recommendation_emitted" },
        "guideline_id": { "type": "string" },
        "recommendation_id": { "type": "string" },
        "status": { "type": "string", "enum": ["due", "up_to_date", "not_applicable", "insufficient_evidence"] },
        "evidence_grade": { "type": "string" },
        "offered_strategies": { "type": "array", "items": { "type": "string" } },
        "satisfying_strategy": { "type": ["string", "null"] },
        "reason": { "type": "string" }
      }
    },
    "EvaluationCompleted": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "required": ["seq", "type", "guideline_id", "recommendations_emitted", "duration_ms"],
      "properties": {
        "type": { "const": "evaluation_completed" },
        "guideline_id": { "const": null },
        "recommendations_emitted": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "CrossGuidelineMatch": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "description": "F26: emitted post-traversal when a MODIFIES edge activates between two emitted Recs. Append-only; does not mutate prior events. Emitted after preemption resolution, before evaluation_completed.",
      "required": ["seq", "type", "guideline_id", "source_rec_id", "target_rec_id", "nature", "note", "source_guideline_id", "target_guideline_id"],
      "properties": {
        "type": { "const": "cross_guideline_match" },
        "guideline_id": { "type": ["string", "null"] },
        "source_rec_id": { "type": "string", "description": "The modifying Recommendation ID" },
        "target_rec_id": { "type": "string", "description": "The modified Recommendation ID" },
        "nature": { "type": "string", "enum": ["intensity_reduction", "dose_adjustment", "monitoring", "contraindication_warning"] },
        "note": { "type": "string" },
        "source_guideline_id": { "type": "string" },
        "target_guideline_id": { "type": "string" }
      }
    },
    "PreemptionResolved": {
      "allOf": [{ "$ref": "#/$defs/BaseEvent" }],
      "description": "F25: emitted post-traversal when a PREEMPTED_BY edge resolves between two emitted Recs. Append-only; does not mutate prior events.",
      "required": ["seq", "type", "guideline_id", "preempted_recommendation_id", "preempting_recommendation_id", "edge_priority", "reason"],
      "properties": {
        "type": { "const": "preemption_resolved" },
        "guideline_id": { "type": ["string", "null"] },
        "preempted_recommendation_id": { "type": "string" },
        "preempting_recommendation_id": { "type": "string" },
        "edge_priority": { "type": "integer" },
        "reason": { "type": "string" }
      }
    },
    "Recommendation": {
      "type": "object",
      "required": ["recommendation_id", "guideline_id", "status", "evidence_grade", "reason"],
      "properties": {
        "recommendation_id": { "type": "string" },
        "guideline_id": { "type": "string" },
        "status": { "type": "string", "enum": ["due", "up_to_date", "not_applicable", "insufficient_evidence"] },
        "evidence_grade": { "type": "string" },
        "offered_strategies": { "type": "array", "items": { "type": "string" } },
        "satisfying_strategy": { "type": ["string", "null"] },
        "reason": { "type": "string" },
        "preempted_by": { "type": ["string", "null"], "description": "recommendation_id of the winning Rec if this Rec is preempted; null otherwise. Computed from preemption_resolved events in the trace." },
        "modifiers": {
          "type": "array",
          "description": "List of active modifiers from cross-guideline MODIFIES edges. Empty if no modifiers. Computed from cross_guideline_match events in the trace.",
          "items": {
            "type": "object",
            "required": ["source_rec_id", "source_guideline_id", "nature", "note"],
            "properties": {
              "source_rec_id": { "type": "string" },
              "source_guideline_id": { "type": "string" },
              "nature": { "type": "string", "enum": ["intensity_reduction", "dose_adjustment", "monitoring", "contraindication_warning"] },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  }
}
